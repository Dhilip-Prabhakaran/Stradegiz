# Copy to .env and fill in. .env is gitignored and must never be committed.
#
# Generate the token from your own Upstox developer app:
#   https://upstox.com/developer/api-documentation/
# Market-data access only — this project never places orders.
#
# NOTE: Upstox access tokens expire daily (early morning IST). The recorder
# will log a clear 401 message when the token goes stale.
UPSTOX_ACCESS_TOKEN=

# Underlyings to record, comma separated.
CAPTURE_UNDERLYINGS=NIFTY,BANKNIFTY

# Snapshot cadence in seconds. 300 = 5 minutes.
CAPTURE_INTERVAL_SECONDS=300
