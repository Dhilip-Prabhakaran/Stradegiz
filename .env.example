# Copy to .env and fill in. .env is gitignored and must never be committed.

# Which provider the recorder uses: "kotak" or "upstox".
DATA_SOURCE=kotak

# --- Kotak Neo (default) ------------------------------------------------
# The app TOKEN from Kotak Neo: Invest -> Trade API -> API Dashboard.
#
# This is the ONLY credential needed. Kotak's market-data endpoints (quotes,
# scrip search) authorise on this key alone — no MPIN, no TOTP, no login.
# Consequences worth knowing:
#   * No daily login ritual; this key is long-lived.
#   * No session is created, so this cannot log out another tool using the
#     same trading account.
#   * Read-only market data. Placing orders would need a TOTP session, which
#     this project never establishes.
#
# Still treat it as a secret: use a SEPARATE Kotak application from any
# trading tool, so it can be reset independently.
KOTAK_CONSUMER_KEY=

# --- Upstox (fallback) --------------------------------------------------
# Only used when DATA_SOURCE=upstox. Market-data access only.
# Tokens expire daily at 03:30 IST; paste with `python -m app.set_token`.
UPSTOX_ACCESS_TOKEN=

# --- Capture ------------------------------------------------------------
# Underlyings to record, comma separated.
CAPTURE_UNDERLYINGS=NIFTY,BANKNIFTY

# Snapshot cadence in seconds. 300 = 5 minutes.
CAPTURE_INTERVAL_SECONDS=300
