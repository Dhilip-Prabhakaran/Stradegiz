# Copy to .env and fill in. .env is gitignored and must never be committed.

# Which provider the recorder uses: "kotak" or "upstox".
DATA_SOURCE=kotak

# --- Kotak Neo (default) ------------------------------------------------
# Kotak requires the 2FA session even for market data — calling the scrip or
# quote endpoints with only the consumer key returns
# "Complete the 2fa process before accessing this application".
# So all five values are needed. The TOTP secret is a static seed, so the
# recorder generates each day's code itself and logs in unattended.
#
# SECURITY: these grant full account access, including order placement. This
# project only reads market data. Treat .env like your account password; it is
# gitignored and never logged. Use a SEPARATE Kotak application from any
# trading tool, so this one can be reset independently.
#
#   CONSUMER_KEY : app TOKEN (Invest -> Trade API -> API Dashboard)
#   TOTP_SECRET  : the seed from Menu -> TOTP Registration
#   MOBILE       : registered number with country code, e.g. +919999999999
#   UCC          : client code, found in your profile
#   MPIN         : the 6-digit pin you use in the app
KOTAK_CONSUMER_KEY=
KOTAK_MOBILE=
KOTAK_UCC=
KOTAK_MPIN=
KOTAK_TOTP_SECRET=

# --- Upstox (fallback) --------------------------------------------------
# Only used when DATA_SOURCE=upstox. Market-data access only.
# Tokens expire daily at 03:30 IST; paste with `python -m app.set_token`.
UPSTOX_ACCESS_TOKEN=

# --- Capture ------------------------------------------------------------
# Underlyings to record, comma separated.
# NSE: NIFTY, BANKNIFTY, FINNIFTY, MIDCPNIFTY | BSE: SENSEX, BANKEX
# The recorder resolves the right exchange segment per symbol.
CAPTURE_UNDERLYINGS=NIFTY,BANKNIFTY,SENSEX

# Snapshot cadence in seconds. 300 = 5 minutes.
CAPTURE_INTERVAL_SECONDS=300
