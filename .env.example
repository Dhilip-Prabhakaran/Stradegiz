# Copy to .env and fill in. .env is gitignored and must never be committed.

# Which provider the recorder uses: "kotak" or "upstox".
DATA_SOURCE=kotak

# --- Kotak Neo (default) ------------------------------------------------
# From Kotak Neo: Invest -> Trade API -> API Dashboard -> Create Application.
#
# SECURITY: these credentials grant FULL account access, including order
# placement. This project only reads data, but treat .env like your account
# password — never commit it, never share it. The code reads these from the
# environment and never logs them.
#
# Auth uses a TOTP secret (a static seed), so the recorder logs in
# automatically each day — no manual token paste needed.
KOTAK_CONSUMER_KEY=
KOTAK_CONSUMER_SECRET=
KOTAK_MOBILE=
KOTAK_UCC=
KOTAK_MPIN=
KOTAK_TOTP_SECRET=

# --- Upstox (fallback) --------------------------------------------------
# Only used when DATA_SOURCE=upstox. Market-data access only.
# Tokens expire daily at 03:30 IST; paste with `python -m app.set_token`.
UPSTOX_ACCESS_TOKEN=

# --- Capture ------------------------------------------------------------
# Underlyings to record, comma separated.
CAPTURE_UNDERLYINGS=NIFTY,BANKNIFTY

# Snapshot cadence in seconds. 300 = 5 minutes.
CAPTURE_INTERVAL_SECONDS=300
